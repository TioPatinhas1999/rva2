# GOOGLE_API_KEY: Preferred key for Gemini AI API calls.
# If set, this will be used instead of GEMINI_API_KEY.
GOOGLE_API_KEY=

# GEMINI_API_KEY: Fallback key for Gemini AI API calls.
GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL=
